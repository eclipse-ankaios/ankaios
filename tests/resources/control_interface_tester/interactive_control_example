+*** Settings ***
+Documentation       Tests the authorization of the Control Interface access from workloads using interactive mode.
+
+Resource            ../../resources/ankaios.resource
+Resource            ../../resources/variables.resource
+
+Test Setup       Setup Ankaios for Interactive Control Interface test
+Test Teardown    Teardown Interactive Controller Test
+
+*** Test Cases ***
+
+# [stest->swdd~agent-checks-request-for-authorization~1]
+Allow read write rule with wildcard string allows all read and writes - Interactive Mode
+    # Setup: Start interactive controller with full read/write access
+    Given Start Interactive Controller with access rules
+    ...    allow_rules=[{"type": "StateRule", "operation": "ReadWrite", "filterMask": ["*"]}]
+    ...    deny_rules=[]
+
+    # Action 1: Send hello
+    ${result}=    Interactive Controller sends hello
+    Interactive result shall succeed    ${result}
+
+    # Action 2: Update state with simple workload
+    ${result}=    Interactive Controller updates state with manifest "${CONFIGS_DIR}/simple_state.yaml" and mask "desiredState.workloads.simple"
+    Interactive result shall succeed    ${result}
+
+    # Action 3: Update state with tags
+    ${result}=    Interactive Controller updates state with manifest "${CONFIGS_DIR}/simple_state.yaml" and mask "desiredState.workloads.simple_existing.tags"
+    Interactive result shall succeed    ${result}
+
+    # Action 4: Get complete state
+    ${result}=    Interactive Controller gets state
+    Interactive result shall succeed    ${result}
+
+    # Action 5: Get specific workload state
+    ${result}=    Interactive Controller gets state of fields desiredState.workloads.simple_existing
+    Interactive result shall succeed    ${result}
+
+    # Action 6: Get workload tags
+    ${result}=    Interactive Controller gets state of fields desiredState.workloads.simple_existing.tags
+    Interactive result shall succeed    ${result}
+
+Allow write rule with wildcard denies reads - Interactive Mode
+    # Setup: Start interactive controller with only write access
+    Given Start Interactive Controller with access rules
+    ...    allow_rules=[{"type": "StateRule", "operation": "Write", "filterMask": ["*"]}]
+    ...    deny_rules=[]
+
+    # Action 1: Send hello
+    ${result}=    Interactive Controller sends hello
+    Interactive result shall succeed    ${result}
+
+    # Action 2: Update state should succeed (write permission)
+    ${result}=    Interactive Controller updates state with manifest "${CONFIGS_DIR}/simple_state.yaml" and mask "desiredState.workloads.simple"
+    Interactive result shall succeed    ${result}
+
+    # Action 3: Get state should fail (no read permission)
+    ${result}=    Interactive Controller gets state
+    Interactive result shall fail    ${result}
+
+    # Action 4: Get specific state should also fail
+    ${result}=    Interactive Controller gets state of fields desiredState.workloads.simple_existing
+    Interactive result shall fail    ${result}
+
+Allow read rule with wildcard denies writes - Interactive Mode
+    # Setup: Start interactive controller with only read access
+    Given Start Interactive Controller with access rules
+    ...    allow_rules=[{"type": "StateRule", "operation": "Read", "filterMask": ["*"]}]
+    ...    deny_rules=[]
+
+    # Action 1: Send hello
+    ${result}=    Interactive Controller sends hello
+    Interactive result shall succeed    ${result}
+
+    # Action 2: Update state should fail (no write permission)
+    ${result}=    Interactive Controller updates state with manifest "${CONFIGS_DIR}/simple_state.yaml" and mask "desiredState.workloads.simple"
+    Interactive result shall fail    ${result}
+
+    # Action 3: Get state should succeed (read permission)
+    ${result}=    Interactive Controller gets state
+    Interactive result shall succeed    ${result}
+
+    # Action 4: Get specific state should also succeed
+    ${result}=    Interactive Controller gets state of fields desiredState.workloads.simple_existing
+    Interactive result shall succeed    ${result}
